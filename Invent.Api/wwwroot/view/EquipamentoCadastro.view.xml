<mvc:View
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:form="sap.ui.layout.form"
    controllerName="ui5.gestaoequipamento.controller.EquipamentoCadastro"
>
    <Panel
        headerText="{i18n>tituloPainelCadastro}"
        class=" sapUiSmallMarginTopBottom"
        expandable="true"
        expanded="true"
    >
        <content>
            <form:SimpleForm
                id="formCadastro"
                layout="ResponsiveGridLayout"
            >
                <!-- Título interno -->
                <Title text="{i18n>tituloPainelCadastro}" />

                <!-- Nome -->
                <Label text="{i18n>inputEquipamentoNome}" />
                <Input
                    id="inputNome"
                    type="Text"
                    value="{/nome}"
                    placeholder="{i18n>inputEquipamentoNome}"
                />

                <!-- Tipo -->
                <Label text="{i18n>inputEquipamentoTipo}" />
                <Input
                    id="inputTipo"
                    type="Text"
                    value="{/tipo}"
                    placeholder="{i18n>inputEquipamentoTipo}"
                />

                <!-- Quantidade -->
                <Label text="{i18n>inputEquipamentoQuantidade}" />
                <Input
                    id="inputQuantidade"
                    type="Number"
                    value="{/quantidadeEmEstoque}"
                    placeholder="{i18n>inputEquipamentoQuantidade}"
                />

                <!-- Botão de Cadastrar -->
                <Button
                    id="btnCadastrar"
                    text="{i18n>inputButtonCadastrar}"
                    type="Emphasized"
                    press=".onCadastrar"
                />
            </form:SimpleForm>
        </content>
    </Panel>
</mvc:View>
